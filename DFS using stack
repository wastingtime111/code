#include <bits/stdc++.h>
using namespace std;

const int N = 1e5 + 5;
vector<int> adj[N];
vector<int> visited(N, 0);

void dfs(int start) {
    stack<int> st;
    st.push(start);

    while (!st.empty()) {
        int node = st.top();
        st.pop();

        if (visited[node]) continue;

        visited[node] = 1;
        cout << node << " ";

        // Reverse order e push korle recursive DFS er moto result pabe
        for (int i = adj[node].size() - 1; i >= 0; i--) {
            int child = adj[node][i];
            if (!visited[child]) {
                st.push(child);
            }
        }
    }
}

int main() {
    int n, m;
    cin >> n >> m;

    for (int i = 0; i < m; i++) {
        int u, v;
        cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u); // undirected graph
    }

    dfs(1);
}
